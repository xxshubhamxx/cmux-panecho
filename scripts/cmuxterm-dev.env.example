# Per-developer dogfood credentials for DEBUG dev builds.
#
# Do NOT edit this file by hand and do NOT commit real secrets. Instead run:
#
#   scripts/setup-team-dev.sh
#
# It prompts for your own Stack account, writes ~/.secrets/cmuxterm-dev.env with
# chmod 600, and verifies the credentials against Stack before you build.
#
# This file is only a template. The real file lives at ~/.secrets/cmuxterm-dev.env
# (outside the repo, never tracked). DEBUG builds read it via
# DebugDogfoodCredentialResolver (macOS) and scripts/lib/dev-secrets.sh (iOS),
# so a tagged dev build signs in as YOU and auto-attaches to YOUR Mac.

CMUX_DOGFOOD_STACK_EMAIL=you@example.com
CMUX_DOGFOOD_STACK_PASSWORD=your-stack-password
