+#include "mojo/public/cpp/system/invitation.h"
+
+namespace {
+
+struct GlobalState {
+  base::AtExitManager at_exit;
+  std::unique_ptr<base::SingleThreadTaskExecutor> main_executor;
+  std::unique_ptr<base::Thread> ipc_thread;
+  std::unique_ptr<mojo::core::ScopedIPCSupport> ipc_support;
+  bool initialized = false;
+};
+
+GlobalState& GetGlobal() {
+  static base::NoDestructor<GlobalState> global;
+  return *global;
+}
+
+void Emit(OwlFreshEventCallback callback,
+          void* user_data,
+          const OwlFreshEvent& event) {
+  if (callback) {
+    callback(&event, user_data);
+  }
+}
+
+char* DuplicateCString(const std::string& value) {
+  char* copy = static_cast<char*>(std::malloc(value.size() + 1));
+  if (!copy) {
+    return nullptr;
+  }
+  // SAFETY: `copy` was allocated as `value.size() + 1` bytes above.
+  auto [text, terminator] =
+      UNSAFE_BUFFERS(base::span<char>(copy, value.size() + 1))
+          .split_at(value.size());
+  text.copy_from(base::span(std::string_view(value)));
+  terminator.copy_from(base::span_from_ref('\0'));
+  return copy;
+}
+
+}  // namespace
+
+struct OwlFreshSession;
+
+class OwlFreshClientImpl final : public content::mojom::OwlFreshClient {
+ public:
+  explicit OwlFreshClientImpl(OwlFreshSession* session) : session_(session) {}
+  ~OwlFreshClientImpl() override = default;
+
+  void OnReady(int32_t host_pid,
+               content::mojom::OwlFreshCompositorInfoPtr compositor) override;
+  void OnCompositorChanged(
+      content::mojom::OwlFreshCompositorInfoPtr compositor) override;
+  void OnNavigationChanged(const std::string& url,
+                           const std::string& title,
+                           bool loading) override;
+  void OnHostLog(const std::string& message) override;
+
+ private:
+  raw_ptr<OwlFreshSession> session_;
+};
+
+struct OwlFreshSession {
+  base::Process process;
+  mojo::Remote<content::mojom::ShellController> controller;
+  mojo::Remote<content::mojom::OwlFreshHost> host;
+  std::unique_ptr<OwlFreshClientImpl> client_impl;
+  std::unique_ptr<mojo::Receiver<content::mojom::OwlFreshClient>>
+      client_receiver;
+  OwlFreshEventCallback callback = nullptr;
+  raw_ptr<void> user_data = nullptr;
+};
+
+void OwlFreshClientImpl::OnReady(
+    int32_t host_pid,
+    content::mojom::OwlFreshCompositorInfoPtr compositor) {
+  OwlFreshEvent event = {};
+  event.kind = kOwlFreshEventReady;
+  event.host_pid = host_pid;
+  event.context_id = compositor ? compositor->context_id : 0;
+  Emit(session_->callback, session_->user_data, event);
+}
+
+void OwlFreshClientImpl::OnCompositorChanged(
+    content::mojom::OwlFreshCompositorInfoPtr compositor) {
+  OwlFreshEvent event = {};
+  event.kind = kOwlFreshEventCompositor;
+  event.context_id = compositor ? compositor->context_id : 0;
+  Emit(session_->callback, session_->user_data, event);
+}
+
+void OwlFreshClientImpl::OnNavigationChanged(const std::string& url,
+                                             const std::string& title,
+                                             bool loading) {
+  OwlFreshEvent event = {};
+  event.kind = kOwlFreshEventNavigation;
+  event.url = url.c_str();
+  event.title = title.c_str();
+  event.loading = loading;
+  Emit(session_->callback, session_->user_data, event);
+}
+
+void OwlFreshClientImpl::OnHostLog(const std::string& message) {
+  OwlFreshEvent event = {};
+  event.kind = kOwlFreshEventLog;
+  event.message = message.c_str();
+  Emit(session_->callback, session_->user_data, event);
+}
+
+extern "C" int owl_fresh_global_init(void) {
+  GlobalState& global = GetGlobal();
+  if (global.initialized) {
+    return 0;
+  }
+
+  base::apple::SetBaseBundleIDOverride("org.chromium.ContentShell");
+
+  const char* argv[] = {"owl_fresh_bridge"};
+  base::CommandLine::Init(1, argv);
+  logging::SetMinLogLevel(logging::LOGGING_INFO);
+
+  base::ThreadPoolInstance::CreateAndStartWithDefaultParams(
+      "owl_fresh_bridge");
+
+  mojo::core::Configuration config;
+  config.is_broker_process = true;
+  config.max_message_num_bytes = 128 * 1024 * 1024;
+  mojo::core::Init(config);
+
+  global.ipc_thread = std::make_unique<base::Thread>("owl_fresh_ipc");
+  base::Thread::Options options;
+  options.message_pump_type = base::MessagePumpType::IO;
+  if (!global.ipc_thread->StartWithOptions(std::move(options))) {
+    return 1;
+  }
+  global.ipc_support = std::make_unique<mojo::core::ScopedIPCSupport>(
+      global.ipc_thread->task_runner(),
+      mojo::core::ScopedIPCSupport::ShutdownPolicy::CLEAN);
+  global.main_executor = std::make_unique<base::SingleThreadTaskExecutor>();
+  global.initialized = true;
+  return 0;
+}
+
+extern "C" OwlFreshSession* owl_fresh_session_create(
+    const char* content_shell_path,
+    const char* initial_url,
+    const char* user_data_dir,
+    OwlFreshEventCallback callback,
+    void* user_data) {
+  if (!GetGlobal().initialized || !content_shell_path || !*content_shell_path) {
+    return nullptr;
+  }
+
+  mojo::PlatformChannel channel;
+  base::LaunchOptions launch_options;
+  base::FilePath program_path(content_shell_path);
+  base::CommandLine command_line(program_path);
+  command_line.AppendSwitch("no-sandbox");
+  const bool visible_control_mode = std::getenv("OWL_FRESH_NO_EMBED") != nullptr;
+  if (!visible_control_mode) {
+    command_line.AppendSwitch("fresh-owl-embed");
+  } else {
+    command_line.AppendSwitch("owl-fresh-visible-control");
+  }
+  command_line.AppendSwitch("owl-fresh-disable-devtools");
+  if (std::getenv("OWL_FRESH_WINDOW_SNAPSHOT") != nullptr) {
+    command_line.AppendSwitch("owl-fresh-window-snapshot");
+  }
+  if (std::getenv("OWL_FRESH_LAYER_FIXTURE") != nullptr) {
+    command_line.AppendSwitch("owl-fresh-layer-fixture-context");
+  }
+  command_line.AppendSwitch("content-shell-hide-toolbar");
+  command_line.AppendSwitch("no-first-run");
+  command_line.AppendSwitch("no-default-browser-check");
+  if (std::getenv("OWL_FRESH_DISABLE_GPU") != nullptr) {
+    command_line.AppendSwitch("disable-gpu");
+  }
+  if (std::getenv("OWL_FRESH_NO_IN_PROCESS_GPU") == nullptr) {
+    command_line.AppendSwitch("in-process-gpu");
+  }
+  command_line.AppendSwitchASCII("enable-logging", "stderr");
+  command_line.AppendSwitchASCII("vmodule", "*owl*=1,*fresh*=1,*shell*=1");
+  if (user_data_dir && *user_data_dir) {
+    command_line.AppendSwitchASCII("user-data-dir", user_data_dir);
+  }
+  if (initial_url && *initial_url) {
+    command_line.AppendArg(initial_url);
+  }
+  channel.PrepareToPassRemoteEndpoint(&launch_options, &command_line);
+
+  base::Process process = base::LaunchProcess(command_line, launch_options);
+  channel.RemoteProcessLaunchAttempted();
+  if (!process.IsValid()) {
+    return nullptr;
+  }
+
+  auto session = std::make_unique<OwlFreshSession>();
+  session->callback = callback;
+  session->user_data = user_data;
+  session->process = std::move(process);
+
+  mojo::OutgoingInvitation invitation;
+  session->controller =
+      mojo::Remote<content::mojom::ShellController>(
+          mojo::PendingRemote<content::mojom::ShellController>(
+              invitation.AttachMessagePipe(0), 0));
+  mojo::OutgoingInvitation::Send(std::move(invitation),
+                                 session->process.Handle(),
+                                 channel.TakeLocalEndpoint());
+
+  session->controller->BindOwlFreshHost(
+      session->host.BindNewPipeAndPassReceiver());
+  session->client_impl = std::make_unique<OwlFreshClientImpl>(session.get());
+  session->client_receiver =
+      std::make_unique<mojo::Receiver<content::mojom::OwlFreshClient>>(
+          session->client_impl.get());
+  session->host->SetClient(
+      session->client_receiver->BindNewPipeAndPassRemote());
+
+  session->controller.set_disconnect_handler(base::BindRepeating(
+      [](OwlFreshSession* session) {
+        OwlFreshEvent event = {};
+        event.kind = kOwlFreshEventDisconnected;
+        Emit(session->callback, session->user_data, event);
+      },
+      session.get()));
+  session->host.set_disconnect_handler(base::BindRepeating(
+      [](OwlFreshSession* session) {
+        OwlFreshEvent event = {};
+        event.kind = kOwlFreshEventDisconnected;
+        Emit(session->callback, session->user_data, event);
+      },
+      session.get()));
+
+  return session.release();
+}
+
+extern "C" void owl_fresh_session_destroy(OwlFreshSession* session) {
+  if (!session) {
+    return;
+  }
+  if (session->controller.is_bound()) {
+    session->controller->ShutDown();
+  }
+  session->host.reset();
+  session->controller.reset();
+  base::RunLoop loop;
+  base::SingleThreadTaskRunner::GetCurrentDefault()->PostDelayedTask(
+      FROM_HERE, loop.QuitClosure(), base::Milliseconds(100));
+  loop.Run();
+  session->process.WaitForExitWithTimeout(base::Seconds(2), nullptr);
+  delete session;
+}
+
+extern "C" int32_t owl_fresh_session_host_pid(OwlFreshSession* session) {
+  return session && session->process.IsValid() ? session->process.Pid() : -1;
+}
+
+extern "C" void owl_fresh_navigate(OwlFreshSession* session, const char* url) {
+  if (session && session->host.is_bound() && url) {
+    session->host->Navigate(url);
+  }
+}
+
+extern "C" void owl_fresh_resize(OwlFreshSession* session,
+                                 uint32_t width,
+                                 uint32_t height,
+                                 float scale) {
+  if (session && session->host.is_bound()) {
+    session->host->Resize(width, height, scale);
+  }
+}
+
+extern "C" void owl_fresh_set_focus(OwlFreshSession* session, bool focused) {
+  if (session && session->host.is_bound()) {
+    session->host->SetFocus(focused);
+  }
+}
+
+extern "C" void owl_fresh_send_mouse(OwlFreshSession* session,
+                                     uint32_t kind,
+                                     float x,
+                                     float y,
+                                     uint32_t button,
+                                     uint32_t click_count,
+                                     float delta_x,
+                                     float delta_y,
+                                     uint32_t modifiers) {
+  if (!session || !session->host.is_bound()) {
+    return;
+  }
+  auto event = content::mojom::OwlFreshMouseEvent::New();
+  event->kind = static_cast<content::mojom::OwlFreshMouseKind>(kind);
+  event->x = x;
+  event->y = y;
+  event->button = button;
+  event->click_count = click_count;
+  event->delta_x = delta_x;
+  event->delta_y = delta_y;
+  event->modifiers = modifiers;
+  session->host->SendMouse(std::move(event));
+}
+
+extern "C" void owl_fresh_send_key(OwlFreshSession* session,
+                                   bool key_down,
+                                   uint32_t key_code,
+                                   const char* text,
+                                   uint32_t modifiers) {
+  if (!session || !session->host.is_bound()) {
+    return;
+  }
+  auto event = content::mojom::OwlFreshKeyEvent::New();
+  event->key_down = key_down;
+  event->key_code = key_code;
+  event->text = text ? text : "";
+  event->modifiers = modifiers;
+  session->host->SendKey(std::move(event));
+}
+
+extern "C" int owl_fresh_capture_surface_png(OwlFreshSession* session,
+                                             uint8_t** png_bytes,
+                                             uintptr_t* png_length,
+                                             uint32_t* width,
+                                             uint32_t* height,
+                                             char** capture_mode,
+                                             char** error) {
+  if (png_bytes) {
+    *png_bytes = nullptr;
+  }
+  if (png_length) {
+    *png_length = 0;
+  }
+  if (width) {
+    *width = 0;
+  }
+  if (height) {
+    *height = 0;
+  }
+  if (capture_mode) {
+    *capture_mode = nullptr;
+  }
+  if (error) {
+    *error = nullptr;
+  }
+
+  if (!session || !session->host.is_bound()) {
+    if (error) {
+      *error = DuplicateCString("OwlFreshSession is not bound");
+    }
+    return 1;
+  }
+
+  int status = 1;
+  base::RunLoop loop;
+  session->host->CaptureSurface(base::BindOnce(
+      [](base::OnceClosure quit,
+         int* status,
+         uint8_t** png_bytes,
+         uintptr_t* png_length,
+         uint32_t* width,
+         uint32_t* height,
+         char** capture_mode,
+         char** error,
+         content::mojom::OwlFreshCaptureResultPtr result) {
+        if (!result) {
+          if (error) {
+            *error = DuplicateCString("CaptureSurface returned no result");
+          }
+          std::move(quit).Run();
+          return;
+        }
+
+        if (width) {
+          *width = result->width;
+        }
+        if (height) {
+          *height = result->height;
+        }
+        if (capture_mode) {
+          *capture_mode = DuplicateCString(result->capture_mode);
+        }
+
+        if (!result->error.empty()) {
+          if (error) {
+            *error = DuplicateCString(result->error);
+          }
+          std::move(quit).Run();
+          return;
+        }
+
+        if (result->png.empty()) {
+          if (error) {
+            *error = DuplicateCString("CaptureSurface returned empty PNG bytes");
+          }
+          std::move(quit).Run();
+          return;
+        }
+
+        uint8_t* bytes =
+            static_cast<uint8_t*>(std::malloc(result->png.size()));
+        if (!bytes) {
+          if (error) {
+            *error = DuplicateCString("failed to allocate PNG output buffer");
+          }
+          std::move(quit).Run();
+          return;
+        }
+        // SAFETY: `bytes` was allocated as `result->png.size()` bytes above.
+        UNSAFE_BUFFERS(base::span<uint8_t>(bytes, result->png.size()))
+            .copy_from(base::span(result->png));
+        if (png_bytes) {
+          *png_bytes = bytes;
+        } else {
+          std::free(bytes);
+        }
+        if (png_length) {
+          *png_length = result->png.size();
+        }
+        *status = 0;
+        std::move(quit).Run();
+      },
+      loop.QuitClosure(), &status, png_bytes, png_length, width, height,
+      capture_mode, error));
+  loop.Run();
+  return status;
+}
+
+extern "C" int owl_fresh_execute_javascript(OwlFreshSession* session,
+                                            const char* script,
+                                            char** result_json,
+                                            char** error) {
+  if (result_json) {
+    *result_json = nullptr;
+  }
+  if (error) {
+    *error = nullptr;
+  }
+
+  if (!session || !session->controller.is_bound()) {
+    if (error) {
+      *error = DuplicateCString("ShellController is not bound");
+    }
+    return 1;
+  }
+  if (!script) {
+    if (error) {
+      *error = DuplicateCString("script is null");
+    }
+    return 1;
+  }
+
+  int status = 1;
+  base::RunLoop loop;
+  session->controller->ExecuteJavaScript(
+      base::UTF8ToUTF16(script),
+      base::BindOnce(
+          [](base::OnceClosure quit,
+             int* status,
+             char** result_json,
+             char** error,
+             base::Value result) {
+            std::string json;
+            if (!base::JSONWriter::Write(result, &json)) {
+              if (error) {
+                *error = DuplicateCString("JSONWriter failed");
+              }
+              std::move(quit).Run();
+              return;
+            }
+            if (result_json) {
+              *result_json = DuplicateCString(json);
+            }
+            *status = 0;
+            std::move(quit).Run();
+          },
+          loop.QuitClosure(), &status, result_json, error));
+  loop.Run();
+  return status;
+}
+
+extern "C" void owl_fresh_poll_events(uint32_t timeout_ms) {
+  base::RunLoop loop;
+  base::SingleThreadTaskRunner::GetCurrentDefault()->PostDelayedTask(
+      FROM_HERE, loop.QuitClosure(), base::Milliseconds(timeout_ms));
+  loop.Run();
+}
+
+extern "C" void owl_fresh_free_buffer(void* buffer) {
+  std::free(buffer);
+}
