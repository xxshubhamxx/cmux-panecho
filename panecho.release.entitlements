<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!--
	  Panecho Developer ID (non-App-Store) entitlements.

	  Verified empirically (errno 153 / "Launchd job spawn failed"): a
	  Developer-ID-signed app must NOT carry restricted entitlements that
	  require a provisioning profile, or amfi kills it at spawn. Dropped vs
	  cmux.release.entitlements:
	    - com.apple.application-identifier        (profile-bound)
	    - com.apple.developer.team-identifier     (profile-bound)
	    - com.apple.developer.web-browser.public-key-credential
	          (RESTRICTED capability; needs a managed provisioning profile.
	           Under Developer ID with no profile the app fails to launch.
	           In-app-browser passkeys are therefore unavailable until
	           io.panecho.app is registered for this capability under team
	           YQ5FZQ855D and a managed profile is embedded.)

	  Sign with scripts/sign-panecho-bundle.sh (NOT sign-cmux-bundle.sh,
	  which hard-requires the web-browser entitlement).
	-->
	<key>com.apple.security.cs.allow-jit</key>
	<true/>
	<key>com.apple.security.cs.allow-unsigned-executable-memory</key>
	<true/>
	<key>com.apple.security.cs.disable-library-validation</key>
	<true/>
	<key>com.apple.security.automation.apple-events</key>
	<true/>
	<key>com.apple.security.device.audio-input</key>
	<true/>
	<key>com.apple.security.device.camera</key>
	<true/>
</dict>
</plist>
