// Panecho enterprise privacy overlay.
// Apply with: xcodebuild -xcconfig Config/PrivacyOverrides.xcconfig ...
// This file intentionally stays detached from project.pbxproj so upstream pulls remain low-conflict.

PANECHO_PRODUCT_NAME = Panecho
PANECHO_BUNDLE_IDENTIFIER = io.panecho.app
PANECHO_AUTH_CALLBACK_SCHEME = panecho

PRODUCT_NAME = $(PANECHO_PRODUCT_NAME)
PRODUCT_BUNDLE_IDENTIFIER = $(PANECHO_BUNDLE_IDENTIFIER)
INFOPLIST_KEY_CFBundleDisplayName = $(PANECHO_PRODUCT_NAME)
CMUX_AUTH_CALLBACK_SCHEME = $(PANECHO_AUTH_CALLBACK_SCHEME)

SWIFT_ACTIVE_COMPILATION_CONDITIONS = $(inherited) PRIVACY_MODE
GCC_PREPROCESSOR_DEFINITIONS = $(inherited) PRIVACY_MODE=1
