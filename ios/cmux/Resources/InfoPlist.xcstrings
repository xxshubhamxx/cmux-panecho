{
  "sourceLanguage": "en",
  "strings": {
    "NSCameraUsageDescription": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "cmux-Kopplungs-QR-Codes vom Mac-Terminal scannen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Scan cmux pairing QR codes from your Mac terminal."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Escanear códigos QR de emparejamiento de cmux desde tu terminal Mac."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Scannez les QR de jumelage cmux depuis votre terminal Mac."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Scansiona i QR code di abbinamento cmux dal terminale del tuo Mac."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Mac のターミナルに表示された cmux のペアリング QR コードをスキャンします。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Mac 터미널에서 cmux 페어링 QR 코드를 스캔합니다."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Scan cmux-koppel-QR-codes van je Mac-terminal."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Skanuj kody QR parowania cmux z terminala Mac."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Escanear QR codes de pareamento do cmux a partir do seu terminal Mac."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Сканирование QR-кодов сопряжения cmux с вашего Mac."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Mac terminalinizden cmux eşleştirme QR kodlarını tarayın."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "扫描 Mac 终端上的 cmux 配对二维码。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "掃描來自 Mac 終端機的 cmux 配對 QR 碼。"
          }
        }
      }
    },
    "NSLocalNetworkUsageDescription": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Verbindung zum Mac im lokalen Netzwerk für cmux-Mobile-Kopplung und Terminal-Sync herstellen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Connect to your Mac on the local network for cmux mobile pairing and terminal sync."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Conectarse a tu Mac en la red local para el emparejamiento móvil de cmux y la sincronización del terminal."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Connectez-vous à votre Mac sur le réseau local pour le jumelage mobile cmux et la synchronisation du terminal."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Connettiti al tuo Mac sulla rete locale per l'abbinamento mobile cmux e la sincronizzazione del terminale."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "cmux モバイルのペアリングとターミナル同期のため、ローカルネットワーク上の Mac に接続します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "cmux 모바일 페어링 및 터미널 동기화를 위해 로컬 네트워크의 Mac에 연결합니다."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Verbinding maken met je Mac op het lokale netwerk voor cmux-mobiel koppelen en terminalsynchronisatie."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Połącz się z Macem w sieci lokalnej w celu parowania mobilnego cmux i synchronizacji terminala."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Conectar ao seu Mac na rede local para pareamento móvel e sincronização de terminal do cmux."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Подключение к Mac в локальной сети для мобильного сопряжения и синхронизации терминала cmux."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "cmux mobil eşleştirme ve terminal senkronizasyonu için yerel ağdaki Mac'inize bağlanın."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "通过本地网络连接到您的 Mac，用于 cmux 移动端配对和终端同步。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "透過區域網路連線至您的 Mac，以進行 cmux 行動裝置配對和終端機同步。"
          }
        }
      }
    },
    "NSMicrophoneUsageDescription": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Audio aufnehmen, um Sprache in das Nachrichtenfeld zu transkribieren."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Record audio to transcribe your voice into the message box."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Grabar audio para transcribir tu voz en el cuadro de mensaje."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Enregistrez de l'audio pour transcrire votre voix dans la zone de message."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Registra audio per trascrivere la tua voce nella casella dei messaggi."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "音声をメッセージ欄に文字起こしするため、音声を録音します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "음성을 녹음하여 메시지 박스에 텍스트로 변환합니다."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Audio opnemen om je stem te transcriberen in het berichtvak."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Nagraj dźwięk, aby transkrybować głos do pola wiadomości."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Gravar áudio para transcrever sua voz na caixa de mensagem."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Запись аудио для транскрибации голоса в поле сообщения."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Sesinizi mesaj kutusuna dönüştürmek için ses kaydedin."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "录制音频以将语音转录到消息框中。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "錄製音訊以將語音轉錄至訊息輸入框。"
          }
        }
      }
    },
    "NSPhotoLibraryUsageDescription": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Fotos anhängen, um sie an den Terminal-Agenten zu senden."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Attach photos to send to your terminal agent."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Adjuntar fotos para enviar al agente de tu terminal."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Joignez des photos à envoyer à votre agent de terminal."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Allega foto da inviare all'agente del terminale."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ターミナルのエージェントに送信する写真を添付します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "터미널 에이전트에게 전송할 사진을 첨부합니다."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Foto's bijvoegen om naar je terminalagent te sturen."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Dołączaj zdjęcia do wysyłania do agenta terminala."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Anexar fotos para enviar ao seu agente de terminal."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Прикрепление фотографий для отправки агенту в терминале."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Terminal ajanınıza göndermek için fotoğraf ekleyin."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "附加照片发送给终端 agent。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "附加照片以傳送至您的終端機代理。"
          }
        }
      }
    },
    "NSSpeechRecognitionUsageDescription": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Sprache in das Nachrichtenfeld transkribieren."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Transcribe your speech into the message box."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Transcribir tu voz en el cuadro de mensaje."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Transcrivez votre discours dans la zone de message."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Trascrivi il tuo parlato nella casella dei messaggi."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "音声をメッセージ欄に文字起こしします。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "음성을 메시지 박스에 텍스트로 변환합니다."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Je spraak transcriberen in het berichtvak."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Transkrybuj mowę do pola wiadomości."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Transcrever sua fala na caixa de mensagem."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Транскрибация речи в поле сообщения."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Konuşmanızı mesaj kutusuna dönüştürün."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "将您的语音转录到消息框中。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "將您的語音轉錄至訊息輸入框。"
          }
        }
      }
    }
  },
  "version": "1.0"
}
