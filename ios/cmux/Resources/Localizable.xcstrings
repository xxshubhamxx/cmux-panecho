      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Switch which Mac this device controls. Pairing another Mac keeps the others, so you can hop between them."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このデバイスが操作するMacを切り替えます。別のMacをペアリングしても他のMacは保持されるので、行き来できます。"
          }
        }
      }
    },
