    "mobile.pairing.connectionFailedFormat": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Could not reach %@:%d. Check that the host is reachable over Tailscale or LAN and that the port is correct."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%@:%d に到達できませんでした。ホストが Tailscale または LAN 経由で到達可能で、ポートが正しいことを確認してください。"
          }
        }
      }
    },
    "mobile.pairing.connectionTimedOutFormat": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No response from %@:%d. Make sure the host app is open and accepting mobile connections."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%@:%d から応答がありません。ホストアプリが開いていて、モバイル接続を受け入れていることを確認してください。"
