          "stringUnit": {
            "state": "translated",
            "value": "Choose which compatible terminal buttons appear on both the chat and terminal keyboard bars. Changes here also update the terminal keyboard bar."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "チャットとターミナル両方のキーボードバーに表示する互換性のあるターミナルボタンを選びます。ここでの変更はターミナルのキーボードバーにも反映されます。"
          }
