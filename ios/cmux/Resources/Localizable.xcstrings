    "mobile.onboarding.connectBody": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your phone has to reach your Mac over the network. The simplest private path is Tailscale: both devices join the same tailnet and connect directly, with no cloud relay. On the same Wi-Fi you can instead type the Mac's local address by hand, but that link is unencrypted, so Tailscale is recommended."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "iPhoneはネットワーク経由でMacに届く必要があります。最もシンプルでプライベートな方法はTailscaleです。両方の端末を同じtailnetに参加させると、クラウド中継なしで直接つながります。同じWi-Fiなら、Macのローカルアドレスを手入力して接続することもできますが、その接続は暗号化されないため、Tailscaleをおすすめします。"
          }
        }
      }
    },
    "mobile.onboarding.connectTitle": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A private link to your Mac"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Macへのプライベートな接続"
          }
        }
      }
    },
    "mobile.onboarding.getStarted": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Get started"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "始める"
          }
        }
      }
    },
    "mobile.onboarding.next": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Next"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "次へ"
          }
        }
      }
    },
    "mobile.onboarding.pairBody": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Make sure cmux on your Mac is signed in to the same account, then scan the pairing QR code it shows (or enter its address by hand). You only do this once per Mac."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Mac版cmuxが同じアカウントでサインインしていることを確認し、表示されるペアリングQRコードを読み取ってください（またはアドレスを手入力します）。これはMacごとに一度だけ行います。"
          }
        }
      }
    },
    "mobile.onboarding.pairTitle": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Pair your Mac"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Macとペアリング"
          }
        }
      }
    },
    "mobile.onboarding.skip": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Skip"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "スキップ"
          }
        }
      }
    },
    "mobile.onboarding.tailscaleAppStoreLink": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Get Tailscale for iPhone"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "iPhone版Tailscaleを入手"
          }
        }
      }
    },
    "mobile.onboarding.tailscaleBody": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Tailscale is a free app that gives your devices a private network. Do this once, on both the phone and the Mac."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Tailscaleは、端末同士をプライベートなネットワークでつなぐ無料アプリです。iPhoneとMacの両方で一度だけ設定してください。"
          }
        }
      }
    },
    "mobile.onboarding.tailscaleLink": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Set up Tailscale on the Mac"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "MacにTailscaleを設定"
          }
        }
      }
    },
    "mobile.onboarding.tailscaleStep1": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Install Tailscale on this phone and on your Mac."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "この端末とMacの両方にTailscaleをインストールします。"
          }
        }
      }
    },
    "mobile.onboarding.tailscaleStep2": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Sign both in to the same Tailscale account so they share one tailnet."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "両方を同じTailscaleアカウントでサインインし、同じtailnetを共有させます。"
          }
        }
      }
    },
    "mobile.onboarding.tailscaleStep3": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Keep both signed in to the same cmux account too. Pairing checks that they match."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "両方を同じcmuxアカウントでもサインインしておきます。ペアリング時に一致を確認します。"
          }
        }
      }
    },
    "mobile.onboarding.tailscaleTitle": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Put both devices on Tailscale"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "両方の端末をTailscaleに入れる"
          }
        }
      }
    },
    "mobile.onboarding.troubleConnecting": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Trouble connecting?"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "接続できないときは"
          }
        }
      }
    },
    "mobile.onboarding.whatBody": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "cmux runs your terminals and AI coding agents on your Mac. This app lets you watch them, type, and get notified when an agent needs you, right from your phone."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "cmuxはMac上でターミナルとAIコーディングエージェントを動かします。このアプリを使えば、iPhoneからその様子を見たり、入力したり、エージェントから呼ばれたときに通知を受け取れます。"
          }
        }
      }
    },
    "mobile.onboarding.whatTitle": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your Mac's terminals, on your phone"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Macのターミナルを、iPhoneで"
          }
        }
      }
    },
    "mobile.pairing.accountMismatch": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This Mac is signed in to a different cmux account. Sign out and sign back in with the account that owns this Mac."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このMacは別のcmuxアカウントでサインインしています。サインアウトして、このMacを所有するアカウントでサインインし直してください。"
          }
        }
      }
    },
    "mobile.pairing.appNotRunning": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your Mac is reachable, but cmux isn't running there (or mobile pairing is off). Open cmux on the Mac, then try again."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Macには接続できますが、cmuxが起動していません（またはモバイルのペア設定がオフです）。Macでcmuxを開いてから、もう一度お試しください。"
          }
        }
      }
    },
    "mobile.pairing.attachTicketExpired": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This pairing link expired. Pair again with a fresh QR/link from that computer."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このペアリングリンクの有効期限が切れました。そのコンピュータの新しい QR/リンクでペアリングしてください。"
          }
        }
      }
    },
    "mobile.pairing.authEnvironmentMismatch": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This dev build is signed in to cmux's development auth environment, so its account can never match a Mac running the release app — even with the same email."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "この開発ビルドは cmux の開発用認証環境にサインインしているため、同じメールアドレスでも、リリース版アプリを実行している Mac のアカウントとは一致しません。"
          }
        }
      }
    },
    "mobile.pairing.authEnvironmentMismatch.devMac": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This iPhone uses cmux's production sign-in, but this Mac runs a dev build on the development auth environment, so their accounts can never match — even with the same email."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "この iPhone は cmux の本番サインインを使用していますが、この Mac は開発用認証環境の開発ビルドを実行しているため、同じメールアドレスでもアカウントは一致しません。"
          }
        }
      }
    },
    "mobile.pairing.authorizationFailed": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Couldn't verify your account with this Mac. Make sure both devices are signed in with the same email, then try again."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "この Mac でアカウントを確認できませんでした。両方のデバイスが同じメールアドレスでサインインしていることを確認してから、もう一度お試しください。"
          }
        }
      }
    },
    "mobile.pairing.cameraDenied": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Camera Access Required"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "カメラへのアクセスが必要です"
          }
        }
      }
    },
    "mobile.pairing.cameraUnavailable": {
      "extractionState": "manual",
