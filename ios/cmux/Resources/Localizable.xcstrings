    "mobile.pairing.localNetworkPermission": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "iOS blocked the connection. Allow cmux to use the Local Network in iOS Settings, then try again."
          }
