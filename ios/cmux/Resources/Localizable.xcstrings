    "mobile.altScreenNotice.explanation": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Full-screen mode mirrors the Mac terminal's exact size, so it may not fill this screen. Claude Code: `/tui default`. Codex: restart with `codex --no-alt-screen`."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "全画面モードは Mac 側ターミナルのサイズをそのまま表示するため、この画面いっぱいに広がらない場合があります。Claude Code: `/tui default`。Codex: `codex --no-alt-screen` で再起動。"
          }
        }
      }
    },
