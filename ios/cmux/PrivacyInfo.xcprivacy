<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- cmux does not track users across apps/websites and embeds no ad/tracking SDKs. -->
	<key>NSPrivacyTracking</key>
	<false/>
	<key>NSPrivacyTrackingDomains</key>
	<array/>

	<!-- First-party data collection. Crash/diagnostics SDKs (e.g. Sentry) are not
	     linked into the iOS app; analytics are first-party product-interaction
	     events sent to the cmux web API (server-side PostHog proxy), gated by an
	     in-app opt-out. Keep in lockstep with the App Store Connect privacy label. -->
	<key>NSPrivacyCollectedDataTypes</key>
	<array>
		<dict>
			<key>NSPrivacyCollectedDataType</key>
			<string>NSPrivacyCollectedDataTypeProductInteraction</string>
			<key>NSPrivacyCollectedDataTypeLinked</key>
			<true/>
			<key>NSPrivacyCollectedDataTypeTracking</key>
			<false/>
			<key>NSPrivacyCollectedDataTypePurposes</key>
			<array>
				<string>NSPrivacyCollectedDataTypePurposeAnalytics</string>
			</array>
		</dict>
	</array>

	<!-- Required-reason API declarations for first-party usage only. -->
	<key>NSPrivacyAccessedAPITypes</key>
	<array>
		<dict>
			<!-- App preferences, onboarding state, push-registration opt-in, and
			     device-registry persistence via UserDefaults / @AppStorage. -->
			<key>NSPrivacyAccessedAPIType</key>
			<string>NSPrivacyAccessedAPICategoryUserDefaults</string>
			<key>NSPrivacyAccessedAPITypeReasons</key>
			<array>
				<string>CA92.1</string>
			</array>
		</dict>
		<dict>
			<!-- Reads the app's own bundle executable modification date for the
			     in-app diagnostic build stamp. -->
			<key>NSPrivacyAccessedAPIType</key>
			<string>NSPrivacyAccessedAPICategoryFileTimestamp</string>
			<key>NSPrivacyAccessedAPITypeReasons</key>
			<array>
				<string>DDA9.1</string>
			</array>
		</dict>
	</array>
</dict>
</plist>
